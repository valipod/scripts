#!/usr/bin/env bash

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    cat <<'EOF'
Usage: ff INPUT [INPUT...] [OPTIONS] OUTPUT

Positional arguments:
  INPUT                Input files (first N-1 bare arguments)
  OUTPUT               Output file (last bare argument)

Stream mapping:
  --v STREAM           Video stream map (default: 0:v:0)
  --a1..a4 STREAM      Audio stream maps (default: 0:a)
  --s1..s7 STREAM      Subtitle stream maps (default: 0:s:0)

Codecs:
  --cv CODEC           Video codec (-c:v)
  --cvc VALUE          Video CRF value
  --ca1..ca4 CODEC     Audio codec (aac|ac3|mp3 have presets, or pass raw)
  --ca1c..ca4c VALUE   Audio quality override (-q)
  --cs1..cs7 CODEC     Subtitle codec (-c:s:N, overrides copy for that stream)

Languages:
  --lv1 LANG           Video language metadata
  --la1..la3 LANG      Audio language metadata
  --ls1..ls7 LANG      Subtitle language metadata

Dispositions:
  --da1..da3 VALUE     Audio disposition (default: a:0=default)
  --ds1..ds3 VALUE     Subtitle disposition (default: s:0=default)

Titles:
  --ta2..ta3 TITLE     Audio stream title
  --ts1..ts7 TITLE     Subtitle stream title

Other:
  --ac VALUE           Audio channels (-ac)
  --af                 Add async audio resampling
  --dts                Alias for --af (async resampling for DTS sources)

Example:
  ff movie.mkv movie.ro.srt movie.en.srt --ca1 aac somepath/movie.mkv
EOF
    exit 0
fi

positional=()
while [ $# -gt 0 ]; do
    case "$1" in
        --v)   v="-map $2"; shift 2 ;;
        --a1)  a1="-map $2"; shift 2 ;;
        --a2)  a2="-map $2 -disposition:a:1 0"; shift 2 ;;
        --a3)  a3="-map $2 -disposition:a:2 0"; shift 2 ;;
        --a4)  a4="-map $2 -disposition:a:3 0"; shift 2 ;;
        --s1)  s1="-map $2"; shift 2 ;;
        --s2)  s2="-map $2 -disposition:s:1 0"; shift 2 ;;
        --s3)  s3="-map $2 -disposition:s:2 0"; shift 2 ;;
        --s4)  s4="-map $2 -disposition:s:3 0"; shift 2 ;;
        --s5)  s5="-map $2 -disposition:s:4 0"; shift 2 ;;
        --s6)  s6="-map $2 -disposition:s:5 0"; shift 2 ;;
        --s7)  s7="-map $2 -disposition:s:6 0"; shift 2 ;;
        --cv)  cv="-c:v $2"; shift 2 ;;
        --cvc) cvc="-crf $2"; shift 2 ;;
        --ca1)
            case "$2" in
                aac) ca1="-c:a:0 libfdk_aac -vbr 4" ;;
                ac3) ca1="-c:a:0 ac3 -b:a 640k" ;;
                mp3) ca1="-c:a:0 libmp3lame -q 2" ;;
                *)   ca1="-c:a:0 $2" ;;
            esac; shift 2 ;;
        --ca1c) ca1c="-q $2"; shift 2 ;;
        --ca2)
            case "$2" in
                aac) ca2="-c:a:1 libfdk_aac -vbr 4" ;;
                ac3) ca2="-c:a:1 ac3 -b:a 640k" ;;
                mp3) ca2="-c:a:1 libmp3lame -q 2" ;;
                *)   ca2="-c:a:1 $2" ;;
            esac; shift 2 ;;
        --ca2c) ca2c="-q $2"; shift 2 ;;
        --ca3)
            case "$2" in
                aac) ca3="-c:a:2 libfdk_aac -vbr 4" ;;
                ac3) ca3="-c:a:2 ac3 -b:a 640k" ;;
                mp3) ca3="-c:a:2 libmp3lame -q 2" ;;
                *)   ca3="-c:a:2 $2" ;;
            esac; shift 2 ;;
        --ca3c) ca3c="-q $2"; shift 2 ;;
        --ca4)
            case "$2" in
                aac) ca4="-c:a:3 libfdk_aac -vbr 4" ;;
                ac3) ca4="-c:a:3 ac3 -b:a 640k" ;;
                mp3) ca4="-c:a:3 libmp3lame -q 2" ;;
                *)   ca4="-c:a:3 $2" ;;
            esac; shift 2 ;;
        --ca4c) ca4c="-q $2"; shift 2 ;;
        --lv1) lv1="-metadata:s:v:0 language=$2"; shift 2 ;;
        --la1) la1="-metadata:s:a:0 language=$2"; shift 2 ;;
        --la2) la2="-metadata:s:a:1 language=$2"; shift 2 ;;
        --la3) la3="-metadata:s:a:2 language=$2"; shift 2 ;;
        --ls1) ls1="-metadata:s:s:0 language=$2"; shift 2 ;;
        --ls2) ls2="-metadata:s:s:1 language=$2"; shift 2 ;;
        --ls3) ls3="-metadata:s:s:2 language=$2"; shift 2 ;;
        --ls4) ls4="-metadata:s:s:3 language=$2"; shift 2 ;;
        --ls5) ls5="-metadata:s:s:4 language=$2"; shift 2 ;;
        --ls6) ls6="-metadata:s:s:5 language=$2"; shift 2 ;;
        --ls7) ls7="-metadata:s:s:6 language=$2"; shift 2 ;;
        --da1) da1="-disposition:a:0 $2"; shift 2 ;;
        --da2) da2="-disposition:a:1 $2"; shift 2 ;;
        --da3) da3="-disposition:a:2 $2"; shift 2 ;;
        --ds1) ds1="-disposition:s:0 $2"; shift 2 ;;
        --ds2) ds2="-disposition:s:1 $2"; shift 2 ;;
        --ds3) ds3="-disposition:s:2 $2"; shift 2 ;;
        --ta2) ta2="-metadata:s:a:1 title=\"$2\""; shift 2 ;;
        --ta3) ta3="-metadata:s:a:2 title=\"$2\""; shift 2 ;;
        --ts1) ts1="-metadata:s:s:0 title=\"$2\""; shift 2 ;;
        --ts2) ts2="-metadata:s:s:1 title=\"$2\""; shift 2 ;;
        --ts3) ts3="-metadata:s:s:2 title=\"$2\""; shift 2 ;;
        --ts4) ts4="-metadata:s:s:3 title=\"$2\""; shift 2 ;;
        --ts5) ts5="-metadata:s:s:4 title=\"$2\""; shift 2 ;;
        --ts6) ts6="-metadata:s:s:5 title=\"$2\""; shift 2 ;;
        --ts7) ts7="-metadata:s:s:6 title=\"$2\""; shift 2 ;;
        --cs1) cs1="-c:s:0 $2"; shift 2 ;;
        --cs2) cs2="-c:s:1 $2"; shift 2 ;;
        --cs3) cs3="-c:s:2 $2"; shift 2 ;;
        --cs4) cs4="-c:s:3 $2"; shift 2 ;;
        --cs5) cs5="-c:s:4 $2"; shift 2 ;;
        --cs6) cs6="-c:s:5 $2"; shift 2 ;;
        --cs7) cs7="-c:s:6 $2"; shift 2 ;;
        --ac)  ac="-ac $2"; shift 2 ;;
        --af)  af="-filter:a:0 aresample=async=1"; shift ;;
        --dts) af="-filter:a:0 aresample=async=1"; shift ;;
        --)    shift; positional+=("$@"); break ;;
        --*)   echo "Unknown option: $1"; exit 1 ;;
        *)     positional+=("$1"); shift ;;
    esac
done

if [ ${#positional[@]} -lt 2 ]; then
    echo "Need at least one input and one output"
    exit 1
fi

# Last positional = target, rest = inputs
target="\"${positional[-1]}\""
inputs=""
input_files=()
for ((i=0; i<${#positional[@]}-1; i++)); do
    inputs="$inputs -i \"${positional[i]}\""
    input_files+=("${positional[i]}")
done

[ -z "$v" ]   && v="-map 0:v:0"
[ -z "$a1" ]  && a1="-map 0:a"
[ -z "$s1" ]  && s1="-map 0:s:0"
[ -z "$da1" ] && da1="-disposition:a:0 default"
[ -z "$ds1" ] && ds1="-disposition:s:0 default"

# Auto-detect subtitle language from input filenames for explicit --sN mappings
for sn in 1 2 3 4 5 6 7; do
    svar="s${sn}"
    lsvar="ls${sn}"
    [ -z "${!svar}" ] && continue
    [ -n "${!lsvar}" ] && continue
    # extract input index from -map N:...
    map_idx=$(echo "${!svar}" | grep -oP '(?<=-map )\d+')
    [ -z "$map_idx" ] && continue
    fname="${input_files[$map_idx]}"
    [ -z "$fname" ] && continue
    case "${fname,,}" in
        *.ro.*|*.rum.*|*.rou.*|*.rom.*|*.ron.*) lang="ron" ;;
        *.en.*|*.eng.*)        lang="eng" ;;
        *.fr.*|*.fre.*|*.fra.*) lang="fre" ;;
        *.de.*|*.ger.*|*.deu.*) lang="ger" ;;
        *.es.*|*.spa.*)        lang="spa" ;;
        *.it.*|*.ita.*)        lang="ita" ;;
        *.pt.*|*.por.*)        lang="por" ;;
        *)                     lang="" ;;
    esac
    [ -n "$lang" ] && eval "$lsvar=\"-metadata:s:s:$((sn - 1)) language=$lang\""
done

cmd="ffmpeg$inputs $v $a1 $a2 $a3 $a4 $s1 $s2 $s3 $s4 $s5 $s6 $s7 -c copy $cv $cvc $ca1 $ca1c $ac $ca2 $ca2c $ca3 $ca3c $ca4 $ca4c $cs1 $cs2 $cs3 $cs4 $cs5 $cs6 $cs7 $lv1 $la1 $la2 $la3 $ls1 $ls2 $ls3 $ls4 $ls5 $ls6 $ls7 $da1 $da2 $da3 $ds1 $ds2 $ds3 -metadata title= -metadata:s:v title= -metadata:s:a:0 title= $ta2 $ta3 $ts1 $ts2 $ts3 $ts4 $ts5 $ts6 $ts7 -max_interleave_delta 0 $af $target"
echo $cmd
read -p "Press enter to continue"
eval $cmd
